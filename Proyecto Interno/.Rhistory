alpha = 0.95,
show.legend = FALSE
) +
geom_text(
data = legend_df,
aes(x = x, y = y - 0.10, label = label),
hjust = 0.5,
size = 4.6,
color = "grey20"
) +
scale_size_manual(
values = c(
"Low supply" = 2.4,
"Medium supply" = 3.8,
"High supply" = 5.2
)
) +
scale_fill_manual(
values = c(
"Low supply" = "#D9E6EC",
"Medium supply" = "#8FAFBE",
"High supply" = "#2F6B84"
)
) +
coord_cartesian(
xlim = c(0.5, 3.5),
