source("00_config.R")
source(file.path(REVIEW_DIR, "06_figures", "00_fig_config.R"))
library(tidyverse)
library(lubridate)
city_lbl_map <- c(
"BOGOTA"   = "Bogotá",
"MEDELLIN" = "Medellín",
"CALI"     = "Cali")
data_paper <- readRDS(file.path(PREP_DIR, "panel_food_paper.rds"))
cord       <- readRDS(file.path(CORD_DIR, "cord_results.rds"))
deflator   <- readRDS(file.path(PREP_DIR, "deflator_monthly.rds")) %>%
filter(ciudad != "NACIONAL") %>%
select(ciudad, fecha, deflator)
# -----------------------------------------------------------------------
# Group labels
# -----------------------------------------------------------------------
GROUP_LABS <- c(
"Grasas"                                                 = "Fats",
"Leche y productos lácteos"                              = "Dairy",
"Carnes, huevos, leguminosas, frutos secos y semillas"   = "Meat, eggs & legumes",
"Azúcares"                                               = "Sugars",
"Cereales, raíces, tubérculos y plátanos"                = "Cereals & starches",
"Frutas"                                                 = "Fruits",
"Verduras"                                               = "Vegetables")
# -----------------------------------------------------------------------
# Build cord_cost
# -----------------------------------------------------------------------
cord_cost <- cord$comp %>%
mutate(fecha = as.Date(fecha)) %>%
filter(fecha >= PAPER_START, fecha <= PAPER_END) %>%
left_join(
data_paper %>%
mutate(fecha = as.Date(fecha)) %>%
select(ciudad, fecha, articulo, precio_100g,
gramos_g_1_intercambio_1_intercambio) %>%
rename(Food      = articulo,
Serving_g = gramos_g_1_intercambio_1_intercambio),
by = c("ciudad", "fecha", "Food")) %>%
left_join(deflator, by = c("ciudad", "fecha")) %>%
mutate(
cost_contrib = (precio_100g * deflator) * Serving_g / 100 * Number_Serving,
ciudad_lbl   = city_lbl_map[ciudad],
ciudad_lbl   = factor(ciudad_lbl,
levels = c("Bogotá", "Medellín", "Cali")),
Group_en     = recode(Group, !!!GROUP_LABS)) %>%
filter(!is.na(cost_contrib))
# -----------------------------------------------------------------------
# 1. Cost share by food group in CoRD, by city
# -----------------------------------------------------------------------
cat("\n--- Cost share by food group in CoRD, by city ---\n")
cord_cost %>%
group_by(ciudad_lbl, Group_en) %>%
dplyr::summarise(
mean_cost = mean(cost_contrib, na.rm = TRUE),
.groups   = "drop") %>%
group_by(ciudad_lbl) %>%
mutate(pct_cost = round(mean_cost / sum(mean_cost) * 100, 1)) %>%
arrange(ciudad_lbl, desc(pct_cost)) %>%
print(n = 30)
# -----------------------------------------------------------------------
# 2. Real price of CoRD selected foods by city and group
# -----------------------------------------------------------------------
cat("\n--- Real price of CoRD selected foods by city and group ---\n")
cord$comp %>%
mutate(fecha = as.Date(fecha)) %>%
filter(fecha >= PAPER_START, fecha <= PAPER_END,
Number_Serving > 0) %>%
left_join(
data_paper %>%
mutate(fecha = as.Date(fecha)) %>%
select(ciudad, fecha, articulo, precio_100g,
gramos_g_1_intercambio_1_intercambio) %>%
rename(Food      = articulo,
Serving_g = gramos_g_1_intercambio_1_intercambio),
by = c("ciudad", "fecha", "Food")) %>%
left_join(deflator, by = c("ciudad", "fecha")) %>%
mutate(precio_real = precio_100g * deflator) %>%
group_by(ciudad, Group, Food) %>%
dplyr::summarise(
mean_precio_real = round(mean(precio_real, na.rm = TRUE), 1),
.groups          = "drop") %>%
arrange(ciudad, Group, Food) %>%
print(n = 60)
# -----------------------------------------------------------------------
# Precio real de frutas seleccionadas en CoRD por ciudad
# -----------------------------------------------------------------------
cat("\n--- Real price of fruits selected in CoRD by city ---\n")
cord$comp %>%
mutate(fecha = as.Date(fecha)) %>%
filter(fecha >= PAPER_START, fecha <= PAPER_END,
Number_Serving > 0,
Group == "Frutas") %>%
left_join(
data_paper %>%
mutate(fecha = as.Date(fecha)) %>%
select(ciudad, fecha, articulo, precio_100g,
gramos_g_1_intercambio_1_intercambio) %>%
rename(Food      = articulo,
Serving_g = gramos_g_1_intercambio_1_intercambio),
by = c("ciudad", "fecha", "Food")) %>%
left_join(deflator, by = c("ciudad", "fecha")) %>%
mutate(precio_real = precio_100g * deflator) %>%
group_by(ciudad, Food) %>%
dplyr::summarise(
mean_precio_real = round(mean(precio_real, na.rm = TRUE), 1),
pct_months       = round(mean(Number_Serving > 0) * 100, 1),
.groups          = "drop") %>%
arrange(ciudad, mean_precio_real) %>%
print(n = 30)
# -----------------------------------------------------------------------
# Precio real de verduras seleccionadas en CoRD por ciudad
# -----------------------------------------------------------------------
cat("\n--- Real price of vegetables selected in CoRD by city ---\n")
cord$comp %>%
mutate(fecha = as.Date(fecha)) %>%
filter(fecha >= PAPER_START, fecha <= PAPER_END,
Number_Serving > 0,
Group == "Verduras") %>%
left_join(
data_paper %>%
mutate(fecha = as.Date(fecha)) %>%
select(ciudad, fecha, articulo, precio_100g,
gramos_g_1_intercambio_1_intercambio) %>%
rename(Food      = articulo,
Serving_g = gramos_g_1_intercambio_1_intercambio),
by = c("ciudad", "fecha", "Food")) %>%
left_join(deflator, by = c("ciudad", "fecha")) %>%
mutate(precio_real = precio_100g * deflator) %>%
group_by(ciudad, Food) %>%
dplyr::summarise(
mean_precio_real = round(mean(precio_real, na.rm = TRUE), 1),
pct_months       = round(mean(Number_Serving > 0) * 100, 1),
.groups          = "drop") %>%
arrange(ciudad, mean_precio_real) %>%
print(n = 30)
# -----------------------------------------------------------------------
# Precio real de leguminosas seleccionadas en CoRD por ciudad
# -----------------------------------------------------------------------
cat("\n--- Real price of legumes selected in CoRD by city ---\n")
cord$comp %>%
mutate(fecha = as.Date(fecha)) %>%
filter(fecha >= PAPER_START, fecha <= PAPER_END,
Number_Serving > 0,
grepl("Carnes", Group)) %>%
left_join(
data_paper %>%
mutate(fecha = as.Date(fecha)) %>%
select(ciudad, fecha, articulo, precio_100g,
gramos_g_1_intercambio_1_intercambio) %>%
rename(Food      = articulo,
Serving_g = gramos_g_1_intercambio_1_intercambio),
by = c("ciudad", "fecha", "Food")) %>%
left_join(deflator, by = c("ciudad", "fecha")) %>%
mutate(precio_real = precio_100g * deflator) %>%
group_by(ciudad, Food) %>%
dplyr::summarise(
mean_precio_real = round(mean(precio_real, na.rm = TRUE), 1),
pct_months       = round(mean(Number_Serving > 0) * 100, 1),
.groups          = "drop") %>%
arrange(ciudad, mean_precio_real) %>%
print(n = 30)
