# -------------------------------------------------------
# 7. FIGURA 16 (APÉNDICE): TASA CONTRAFACTUAL ANUAL
# -------------------------------------------------------
message("\n[Fig 16] Tasa contrafactual anual (apéndice)...")
cf <- readRDS(cf_path) %>%
mutate(
fecha      = as.Date(fecha),
ano        = year(fecha),
ciudad_lbl = factor(ciudad_lbl, levels = CITY_ORDER),
model      = factor(model, levels = MODEL_ORDER)
) %>%
filter(fecha >= PAPER_START, fecha <= PAPER_END,
!is.na(ciudad_lbl), !is.na(model))
cf_anual <- cf %>%
group_by(ciudad_lbl, model, ano) %>%
summarise(rate = mean(rate, na.rm = TRUE), .groups = "drop")
cf_monthly <- cf %>%
group_by(ciudad_lbl, model, fecha, ano) %>%
summarise(rate = mean(rate, na.rm = TRUE), .groups = "drop")
p16 <- ggplot(cf_monthly,
aes(x = factor(ano), y = rate, fill = ciudad_lbl, color = ciudad_lbl)) +
geom_boxplot(alpha = 0.35, outlier.shape = NA,
position = position_dodge(width = 0.75),
linewidth = 0.45, width = 0.65) +
facet_wrap(~ model, nrow = 3, scales = "free_y") +
scale_fill_manual(values = CITY_COLORS, name = NULL) +
scale_color_manual(values = CITY_COLORS, name = NULL) +
scale_y_continuous(labels = function(x) sprintf("%.0f%%", x), limits = c(0, NA)) +
labs(x = NULL, y = "Tasa de no asequibilidad contrafactual (%)") +
tema_base
ggsave(file.path(out_figuras, "fig_afford_counterfactual.png"),
p16, width = 8, height = 12, dpi = 300, bg = "white")
message("  Figura 16 guardada.")
# -------------------------------------------------------
# 8. TABLAS CONSOLIDADAS
# -------------------------------------------------------
message("\nGuardando tablas...")
writexl::write_xlsx(
list(
rate_gap_decil    = afford_anual_decil %>%
arrange(model, ciudad_lbl, decil_num, ano),
rate_gap_agregado = afford_anual_agg %>%
arrange(model, ciudad_lbl, ano),
rate_mensual_agg  = afford_monthly_agg %>%
arrange(model, ciudad_lbl, fecha),
gap_mensual_agg   = afford_monthly_gap %>%
arrange(model, ciudad_lbl, fecha),
contrafactual     = cf_anual %>%
arrange(model, ciudad_lbl, ano)
),
file.path(out_tablas, "tab_afford_deciles.xlsx")
)
message("  Tabla guardada: tab_afford_deciles.xlsx")
message("\nListo. Outputs en: ", out_dir)
# 1. Tasa anual por decil, ciudad y modelo (años extremos para ver evolución)
afford_anual_decil %>%
filter(ano %in% c(2019, 2024)) %>%
select(model, ciudad_lbl, deciles, decil_num, ano, rate) %>%
pivot_wider(names_from = ano, values_from = rate, names_prefix = "ano_") %>%
mutate(cambio = ano_2024 - ano_2019) %>%
arrange(model, ciudad_lbl, decil_num) %>%
print(n = Inf)
# 2. Decil donde la tasa cruza 50% y donde cruza 0% (frontera de no asequibilidad)
afford_anual_decil %>%
filter(ano %in% c(2019, 2024)) %>%
group_by(model, ciudad_lbl, ano) %>%
summarise(
decil_50pct = decil_num[which.min(abs(rate - 50))],
decil_0pct  = min(decil_num[rate <= 1], default = NA),
max_decil_no_asequible = max(decil_num[rate >= 50], default = 0),
.groups = "drop"
) %>%
arrange(model, ciudad_lbl, ano) %>%
print(n = Inf)
# 3. Año pico de la tasa y de la brecha por decil bajo (1-3) y modelo
afford_anual_decil %>%
filter(decil_num <= 3) %>%
group_by(model, ciudad_lbl, decil_num) %>%
summarise(
ano_pico_rate = ano[which.max(rate)],
rate_pico     = max(rate, na.rm = TRUE),
ano_pico_gap  = ano[which.max(gap)],
gap_pico      = max(gap, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(model, ciudad_lbl, decil_num) %>%
print(n = Inf)
# 4. Brecha anual por decil, ciudad y modelo (años extremos)
afford_anual_decil %>%
filter(ano %in% c(2019, 2024)) %>%
select(model, ciudad_lbl, deciles, decil_num, ano, gap) %>%
pivot_wider(names_from = ano, values_from = gap, names_prefix = "ano_") %>%
mutate(cambio = ano_2024 - ano_2019) %>%
arrange(model, ciudad_lbl, decil_num) %>%
print(n = Inf)
# 1. Serie mensual del Decil 1 por ciudad y modelo (para ver la forma de la curva, no solo el promedio anual)
afford %>%
filter(decil_num == 1) %>%
select(model, ciudad_lbl, fecha, rate) %>%
arrange(model, ciudad_lbl, fecha) %>%
print(n = Inf)
# 2. Mes exacto del pico de tasa por decil bajo (1-3), ciudad y modelo
afford %>%
filter(decil_num <= 3) %>%
group_by(model, ciudad_lbl, decil_num) %>%
summarise(
fecha_pico = fecha[which.max(rate)],
rate_pico  = max(rate, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(model, decil_num, ciudad_lbl) %>%
print(n = Inf)
# 3. Duración del episodio: cuántos meses consecutivos con tasa >= 50% en Decil 1, por ciudad y modelo
afford %>%
filter(decil_num == 1) %>%
group_by(model, ciudad_lbl) %>%
summarise(
n_meses_sobre_50  = sum(rate >= 50, na.rm = TRUE),
n_meses_total     = n(),
pct_tiempo_sobre_50 = round(n_meses_sobre_50 / n_meses_total * 100, 1),
.groups = "drop"
) %>%
arrange(model, ciudad_lbl) %>%
print(n = Inf)
# 4. Volatilidad mensual: desviación estándar de la tasa mensual dentro de cada año, Decil 1-3
afford %>%
filter(decil_num <= 3) %>%
mutate(ano = year(fecha)) %>%
group_by(model, ciudad_lbl, decil_num, ano) %>%
summarise(sd_rate = sd(rate, na.rm = TRUE), .groups = "drop") %>%
group_by(model, ciudad_lbl, decil_num) %>%
summarise(sd_rate_promedio = mean(sd_rate, na.rm = TRUE), .groups = "drop") %>%
arrange(model, decil_num, desc(sd_rate_promedio)) %>%
print(n = Inf)
# 1. Serie mensual del Decil 1 por ciudad y modelo (para ver la forma de la curva, no solo el promedio anual)
afford %>%
filter(decil_num == 1) %>%
select(model, ciudad_lbl, fecha, rate) %>%
arrange(model, ciudad_lbl, fecha) %>%
print(n = Inf)
# 2. Mes exacto del pico de tasa por decil bajo (1-3), ciudad y modelo
afford %>%
filter(decil_num <= 3) %>%
group_by(model, ciudad_lbl, decil_num) %>%
summarise(
fecha_pico = fecha[which.max(rate)],
rate_pico  = max(rate, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(model, decil_num, ciudad_lbl) %>%
print(n = Inf)
# 3. Duración del episodio: cuántos meses consecutivos con tasa >= 50% en Decil 1, por ciudad y modelo
afford %>%
filter(decil_num == 1) %>%
group_by(model, ciudad_lbl) %>%
summarise(
n_meses_sobre_50  = sum(rate >= 50, na.rm = TRUE),
n_meses_total     = n(),
pct_tiempo_sobre_50 = round(n_meses_sobre_50 / n_meses_total * 100, 1),
.groups = "drop"
) %>%
arrange(model, ciudad_lbl) %>%
print(n = Inf)
# 4. Volatilidad mensual: desviación estándar de la tasa mensual dentro de cada año, Decil 1-3
afford %>%
filter(decil_num <= 3) %>%
mutate(ano = year(fecha)) %>%
group_by(model, ciudad_lbl, decil_num, ano) %>%
summarise(sd_rate = sd(rate, na.rm = TRUE), .groups = "drop") %>%
group_by(model, ciudad_lbl, decil_num) %>%
summarise(sd_rate_promedio = mean(sd_rate, na.rm = TRUE), .groups = "drop") %>%
arrange(model, decil_num, desc(sd_rate_promedio)) %>%
print(n = Inf)
# 1. Estadísticos de la distribución mensual de la tasa agregada, por año, ciudad y modelo
afford_monthly_agg %>%
group_by(model, ciudad_lbl, ano) %>%
summarise(
mediana = median(rate, na.rm = TRUE),
q25     = quantile(rate, 0.25, na.rm = TRUE),
q75     = quantile(rate, 0.75, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(model, ciudad_lbl, ano) %>%
print(n = Inf)
# 2. Lo mismo para la brecha agregada
afford_monthly_gap %>%
group_by(model, ciudad_lbl, ano) %>%
summarise(
mediana = median(gap, na.rm = TRUE),
q25     = quantile(gap, 0.25, na.rm = TRUE),
q75     = quantile(gap, 0.75, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(model, ciudad_lbl, ano) %>%
print(n = Inf)
# 3. Cambio en la mediana entre 2019 y 2024 (tasa y brecha agregadas)
afford_monthly_agg %>%
group_by(model, ciudad_lbl, ano) %>%
summarise(mediana_rate = median(rate, na.rm = TRUE), .groups = "drop") %>%
filter(ano %in% c(2019, 2024)) %>%
pivot_wider(names_from = ano, values_from = mediana_rate, names_prefix = "ano_") %>%
mutate(cambio = ano_2024 - ano_2019) %>%
arrange(model, ciudad_lbl) %>%
print(n = Inf)
afford_monthly_gap %>%
group_by(model, ciudad_lbl, ano) %>%
summarise(mediana_gap = median(gap, na.rm = TRUE), .groups = "drop") %>%
filter(ano %in% c(2019, 2024)) %>%
pivot_wider(names_from = ano, values_from = mediana_gap, names_prefix = "ano_") %>%
mutate(cambio = ano_2024 - ano_2019) %>%
arrange(model, ciudad_lbl) %>%
print(n = Inf)
# 4. Contrafactual anual por ciudad y modelo (mediana, para comparar con la tasa real)
cf_monthly %>%
group_by(model, ciudad_lbl, ano) %>%
summarise(
mediana = median(rate, na.rm = TRUE),
q25     = quantile(rate, 0.25, na.rm = TRUE),
q75     = quantile(rate, 0.75, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(model, ciudad_lbl, ano) %>%
print(n = Inf)
# 5. Comparación directa: tasa real (FGT0 agregada) vs. tasa contrafactual, mismo año
afford_monthly_agg %>%
group_by(model, ciudad_lbl, ano) %>%
summarise(rate_real = median(rate, na.rm = TRUE), .groups = "drop") %>%
left_join(
cf_monthly %>%
group_by(model, ciudad_lbl, ano) %>%
summarise(rate_cf = median(rate, na.rm = TRUE), .groups = "drop"),
by = c("model", "ciudad_lbl", "ano")
) %>%
mutate(brecha_cf = rate_real - rate_cf) %>%
arrange(model, ciudad_lbl, ano) %>%
print(n = Inf)
# 1. Tasa contrafactual por decil, ciudad y modelo — 2019 vs 2024
# (necesito saber si cf tiene columna de decil; si no, uso cf como objeto base)
names(cf)
# 2. Si cf tiene deciles, tasa contrafactual por decil en años extremos
cf %>%
mutate(ano = year(fecha)) %>%
filter(ano %in% c(2019, 2024)) %>%
group_by(model, ciudad_lbl, deciles, ano) %>%
summarise(rate = mean(rate, na.rm = TRUE), .groups = "drop") %>%
pivot_wider(names_from = ano, values_from = rate, names_prefix = "ano_") %>%
arrange(model, ciudad_lbl, deciles) %>%
print(n = Inf)
# 3. Si cf NO tiene deciles (ya viene agregado), entonces necesito saber
# qué porcentaje de hogares en el agregado tienen rate = 100 en el contrafactual
# (es decir, ni con el 100% del ingreso alcanzan a costear la dieta)
cf_monthly %>%
mutate(rate_100 = rate >= 99) %>%
group_by(model, ciudad_lbl, ano) %>%
summarise(
pct_meses_rate_100 = mean(rate_100, na.rm = TRUE) * 100,
rate_max           = max(rate, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(model, ciudad_lbl, ano) %>%
print(n = Inf)
# 4. Evolución de la mediana contrafactual 2019 vs 2024 (cambio absoluto)
cf_monthly %>%
group_by(model, ciudad_lbl, ano) %>%
summarise(mediana_cf = median(rate, na.rm = TRUE), .groups = "drop") %>%
filter(ano %in% c(2019, 2024)) %>%
pivot_wider(names_from = ano, values_from = mediana_cf, names_prefix = "ano_") %>%
mutate(cambio = ano_2024 - ano_2019) %>%
arrange(model, ciudad_lbl) %>%
print(n = Inf)
